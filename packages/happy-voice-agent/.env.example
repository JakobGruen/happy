LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-project.livekit.cloud

# LLM model for voice agent (default: claude-haiku-4-5-20251001)
VOICE_AGENT_MODEL=claude-haiku-4-5-20251001

# Pipecat: TURN relay for WebRTC across different networks
# Sign up at metered.ca/stun-turn for free credentials
TURN_URL=turn:a.relay.metered.ca:443?transport=tcp
TURN_USERNAME=
TURN_CREDENTIAL=

# Pipecat: access secret to protect the tunnel URL (optional, skipped if empty)
PIPECAT_ACCESS_SECRET=
