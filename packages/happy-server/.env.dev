# Dev overrides — values from .env are used for anything not set here.
# To use a local DB instead of prod, uncomment the line below:
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/handy
# HANDY_MASTER_SECRET=your-super-secret-key-for-local-development

# Uncomment to enable centralized logging for AI debugging (creates .logs directory)
DANGEROUSLY_LOG_TO_SERVER_FOR_AI_AUTO_DEBUGGING=true

# Disable metrics in dev to avoid port conflicts with production
METRICS_ENABLED=false

NODE_ENV=development
