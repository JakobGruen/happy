{
    "name": "monorepo",
    "private": true,
    "scripts": {
        "cli": "bun run --filter happy-coder cli",
        "web": "bun run --filter happy-app web",
        "ios": "bun run --filter happy-app ios",
        "android": "bun run --filter happy-app android",
        "start": "bun run --filter happy-app start",
        "server": "bun run --filter happy-server dev",
        "server:db": "bun run --filter happy-server db",
        "server:redis": "bun run --filter happy-server redis",
        "wire": "bun run --filter @jakobgruen/happy-wire build",
        "typecheck": "bun run --filter happy-app typecheck",
        "test": "bun run --filter @jakobgruen/happy-wire test && bun run --filter happy-coder test && bun run --filter happy-server test",
        "test:wire": "bun run --filter @jakobgruen/happy-wire test",
        "test:cli": "bun run --filter happy-coder test",
        "test:server": "bun run --filter happy-server test",
        "release": "node ./scripts/release.cjs",
        "dev:reset": "bash scripts/dev-reset.sh",
        "metro:watchdog": "bash scripts/metro-watchdog.sh",
        "postinstall": "node ./scripts/postinstall.cjs"
    },
    "workspaces": {
        "packages": [
            "packages/happy-app",
            "packages/happy-agent",
            "packages/happy-cli",
            "packages/happy-server",
            "packages/happy-wire"
        ],
        "nohoist": [
            "**/zod",
            "**/react",
            "**/react-dom",
            "**/react-native",
            "**/react-native/**",
            "**/react-native-edge-to-edge/**",
            "**/react-native-incall-manager/**"
        ]
    },
    "packageManager": "bun@1.3.10",
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.27.1"
    }
}
